# Copy to local.properties and adjust for your machine.
# DO NOT commit local.properties (already in .gitignore).
sdk.dir=C\:\\Users\\<you>\\AppData\\Local\\Android\\Sdk

# ---- V1.5 alpha autonomous backend config (all optional) ----

# Override the Cloudflare Tunnel URL pointing at your Ollama instance.
# Default: bundled tunnel URL hardcoded in app/build.gradle.kts.
# Quick tunnel URLs change per cloudflared restart; replace as needed.
# ollama.base.url=https\://your-tunnel.trycloudflare.com

# Bake a Picovoice AccessKey into BuildConfig for zero-setup alpha distribution.
# When empty, the user types it once on first launch (Onboarding step 2).
# Get a free key at https://console.picovoice.ai/ (one key works on all your test devices).
# picovoice.access.key=PICOVOICE_ACCESSKEY_HERE
