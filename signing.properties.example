# MamY release signing configuration template
#
# Copy this file to `signing.properties` (gitignored) at repo root and fill
# in the credentials matching your `keystore/mamy-release.jks`.
#
# If signing.properties is absent, release builds fall back to the debug
# signing config so devs can still build a release-mode APK locally for QA.

storeFile=keystore/mamy-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=mamy
keyPassword=YOUR_KEY_PASSWORD
